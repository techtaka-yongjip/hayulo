{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Hayulo",
  "scopeName": "source.hayulo",
  "fileTypes": ["hayulo"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#routeMethods" },
    { "include": "#declarations" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.hayulo",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.hayulo",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.hayulo",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hayulo",
          "match": "\\b-?(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.hayulo",
          "match": "\\b(?:if|else|for|in|return|and|or|not|try|match)\\b"
        },
        {
          "name": "keyword.declaration.hayulo",
          "match": "\\b(?:module|intent|fn|let|set|test|expect|app|database|openapi|type|record|route|body|auth|effect|action)\\b"
        },
        {
          "name": "constant.language.boolean.hayulo",
          "match": "\\b(?:true|false|None)\\b"
        },
        {
          "name": "constant.language.variant.hayulo",
          "match": "\\b(?:Some|Ok|Err)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.hayulo",
          "match": "\\b(?:Text|Int|Float|Bool|Time|Email|Status|Any|List|Id|Option|Result)\\b"
        }
      ]
    },
    "routeMethods": {
      "patterns": [
        {
          "name": "keyword.other.route-method.hayulo",
          "match": "\\b(?:GET|POST|PUT|PATCH|DELETE)\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.function.hayulo",
          "match": "\\bfn\\s+([A-Za-z_]\\w*)",
          "captures": {
            "1": { "name": "entity.name.function.hayulo" }
          }
        },
        {
          "name": "meta.type.hayulo",
          "match": "\\btype\\s+([A-Za-z_]\\w*)",
          "captures": {
            "1": { "name": "entity.name.type.hayulo" }
          }
        },
        {
          "name": "meta.app.hayulo",
          "match": "\\bapp\\s+([A-Za-z_]\\w*)",
          "captures": {
            "1": { "name": "entity.name.type.app.hayulo" }
          }
        }
      ]
    }
  }
}
