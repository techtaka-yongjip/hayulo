module benchmark.webhook_receiver_api

intent {
  purpose: "Baseline for generating a webhook receiver with stored event history."
  constraints: [
    "Accept opaque payload text without executing it.",
    "Expose received events for audit and debugging.",
    "Keep destructive actions explicit."
  ]
}

app WebhookReceiverBenchmarkApi {
  database sqlite "webhook_receiver_benchmark.db"

  openapi {
    title: "Webhook Receiver Benchmark API"
    version: "0.1.0"
  }

  type WebhookEvent = record {
    id: Id<WebhookEvent>
    source: Text min 1 max 120
    event_type: Text min 1 max 120
    payload: Text min 1 max 5000
    processed: Bool = false
    received_at: Time = now()
  }

  route GET "/events" -> List<WebhookEvent> {
    return db.WebhookEvent.all(order: received_at desc)
  }

  route GET "/events/{id}" -> WebhookEvent {
    return db.WebhookEvent.get(id)?
  }

  route POST "/events" body input: IncomingWebhookEvent -> WebhookEvent {
    return db.WebhookEvent.insert(WebhookEvent {
      source: input.source
      event_type: input.event_type
      payload: input.payload
    })
  }

  route PATCH "/events/{id}" body input: UpdateWebhookEvent -> WebhookEvent {
    event = db.WebhookEvent.get(id)?
    return db.WebhookEvent.update(event with { processed: input.processed })
  }

  route DELETE "/events/{id}" -> Status {
    db.WebhookEvent.delete(id)?
    return no_content
  }
}

type IncomingWebhookEvent = record {
  source: Text min 1 max 120
  event_type: Text min 1 max 120
  payload: Text min 1 max 5000
}

type UpdateWebhookEvent = record {
  processed: Bool
}
