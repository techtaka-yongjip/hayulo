module benchmark.support_ticket_api

intent {
  purpose: "Baseline for generating a support ticket API with public and private fields."
  constraints: [
    "Expose customer-visible fields through OpenAPI.",
    "Keep internal notes private in the generated schema.",
    "Support status updates without allowing arbitrary field writes."
  ]
}

app SupportTicketBenchmarkApi {
  database sqlite "support_ticket_benchmark.db"

  openapi {
    title: "Support Ticket Benchmark API"
    version: "0.1.0"
  }

  type Ticket = record {
    id: Id<Ticket>
    requester_email: Email
    summary: Text min 3 max 200
    status: Text min 1 max 40 = "open"
    internal_notes: Text private = ""
    created_at: Time = now()
  }

  route GET "/tickets" -> List<Ticket> {
    return db.Ticket.all(order: created_at desc)
  }

  route GET "/tickets/{id}" -> Ticket {
    return db.Ticket.get(id)?
  }

  route POST "/tickets" body input: CreateTicket -> Ticket {
    return db.Ticket.insert(Ticket {
      requester_email: input.requester_email
      summary: input.summary
    })
  }

  route PATCH "/tickets/{id}" body input: UpdateTicket -> Ticket {
    ticket = db.Ticket.get(id)?
    return db.Ticket.update(ticket with { status: input.status })
  }

  route DELETE "/tickets/{id}" -> Status {
    db.Ticket.delete(id)?
    return no_content
  }
}

type CreateTicket = record {
  requester_email: Email
  summary: Text min 3 max 200
}

type UpdateTicket = record {
  status: Text min 1 max 40
}
