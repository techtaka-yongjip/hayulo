{
  "schema": "hayulo.llm_benchmark.task@0.1",
  "id": "api.inventory",
  "title": "Inventory REST API",
  "category": "rest-api-generation",
  "difficulty": "baseline",
  "prompt": "Generate an inventory REST API for stock items. It must list, get, create, update quantity, and delete items. Validate SKU, name, quantity, and reorder threshold fields.",
  "comparison_targets": ["hayulo", "python-fastapi", "typescript-fastify", "go-stdlib"],
  "success_metrics": ["first_pass_check", "first_pass_tests", "repair_iterations", "validation_correctness", "generated_api_smoke"],
  "expected_outputs": ["source file", "OpenAPI document", "validation behavior", "smoke tests"],
  "hayulo_baseline": "benchmarks/llm/baselines/inventory_api/main.hayulo",
  "manual_checks": [
    "hayulo check benchmarks/llm/baselines/inventory_api/main.hayulo --json",
    "hayulo build benchmarks/llm/baselines/inventory_api/main.hayulo --out /tmp/hayulo-benchmark-inventory --json"
  ]
}
